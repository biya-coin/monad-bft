# 密码变量示例（勿提交明文密码到 git）
# 用法：
#   cp group_vars/validators/password.yml.example group_vars/validators/password.yml
#   vim group_vars/validators/password.yml
#   echo 'password.yml' >> .gitignore  # 在 script-ansible 目录
#
# 或在运行时交互输入（不写文件）：
#   ansible-playbook ... --ask-pass --ask-become-pass

---
ansible_ssh_pass: "your_ssh_password"
ansible_become_pass: "your_sudo_password"
ansible_become_method: sudo
